# PitchPal v2 Environment Configuration

# LLM Provider: gemini (free) | openai | anthropic
LLM_PROVIDER=gemini

# Google Gemini (Free - get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily Search (Free - get key at https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: OpenAI (if using openai provider)
# OPENAI_API_KEY=your_openai_key_here

# Optional: Anthropic (if using anthropic provider)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
